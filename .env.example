# Postgres — são duas URLs pro mesmo banco, com papéis diferentes.

# Usada pelo app em runtime (src/lib/db.ts). No Supabase, use a do
# connection pooler (porta 6543) pra aguentar várias conexões simultâneas.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&sslmode=require"

# Conexão direta (porta 5432), usada só pelo CLI do Prisma (migrate, studio):
# migration não funciona bem via pooler em modo transaction. Quem lê é o
# prisma.config.ts — sem ela, todo comando do Prisma falha com
# "Connection url is empty".
DIRECT_URL="postgresql://user:password@host:5432/postgres?sslmode=require"

# NextAuth
# Gere um valor com: npx auth secret
AUTH_SECRET="troque-por-um-valor-aleatorio-longo"

# Pusher (crie uma conta grátis em https://pusher.com -> Channels)
PUSHER_APP_ID=""
NEXT_PUBLIC_PUSHER_KEY=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_CLUSTER=""

# Opcional: verificação de assinatura da Kiwify (Configurações > Webhooks no painel Kiwify)
KIWIFY_WEBHOOK_SECRET=""

# Opcional: verificação de assinatura da SMPay (secret gerado ao criar o webhook no painel SMPay)
SMPAY_WEBHOOK_SECRET=""

# Não precisa de WEBHOOK_TOKEN aqui: cada produtor tem seu próprio token,
# gerado em /dashboard/produtores.
