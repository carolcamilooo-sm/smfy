# Postgres (ex: crie um banco grátis em https://neon.tech)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth
# Gere um valor com: npx auth secret
AUTH_SECRET="troque-por-um-valor-aleatorio-longo"

# Pusher (crie uma conta grátis em https://pusher.com -> Channels)
PUSHER_APP_ID=""
NEXT_PUBLIC_PUSHER_KEY=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_CLUSTER=""

# Token compartilhado exigido em todo webhook: /api/webhooks/<gateway>?token=SEU_TOKEN
WEBHOOK_TOKEN="troque-por-um-token-aleatorio"

# Opcional: verificação de assinatura da Kiwify (Configurações > Webhooks no painel Kiwify)
KIWIFY_WEBHOOK_SECRET=""
