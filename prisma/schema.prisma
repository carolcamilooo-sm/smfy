generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  OPERATOR
  COLLABORATOR
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OperatorStatus {
  ONLINE
  OFFLINE
}

enum Gateway {
  KIWIFY
  PERFECTPAY
  DISRUPTY
  SMPAY
  PAYT
}

enum PaymentStatus {
  APPROVED
  PENDING
  DECLINED
  OTHER
}

enum ServiceStatus {
  WAITING
  ASSIGNED
  ATTENDED
}

enum LeadEventAction {
  ASSIGNED
  ATTENDED
}

model User {
  id             String           @id @default(cuid())
  name           String
  email          String           @unique
  passwordHash   String
  role           Role             @default(OPERATOR)
  approvalStatus ApprovalStatus   @default(APPROVED)
  status         OperatorStatus   @default(OFFLINE)
  active         Boolean          @default(true)
  priority       Boolean          @default(false)
  notifySound       Boolean       @default(true)
  notifyIdleWarning Boolean       @default(true)
  salesWebhookToken String?       @unique
  // URL da extensão do atendente. O app faz POST do lead aqui quando ele
  // usa "Atender por hook" — é saída, ao contrário do salesWebhookToken,
  // que é entrada (o gateway posta pra cá).
  attendWebhookUrl  String?
  dashboardLayout String[]        @default([])
  dashboardBlockWidths Json       @default("{}")
  lastActivityAt DateTime         @default(now())
  createdAt      DateTime         @default(now())

  // Grupos de atendimento de que a conta participa. É muitos-pra-muitos: a
  // mesma pessoa pode estar no grupo de uma demanda e no de outra, com a % de
  // cada um valendo na demanda dele.
  groups         AttendanceGroup[] @relation("GroupMembers")

  distributionRule DistributionRule?
  assignedLeads     Lead[]          @relation("AssignedLeads")
  leadEvents        LeadEvent[]
  productAccesses   ProductAccess[]
  messageTemplates  MessageTemplate[]
  operatorSales     OperatorSale[]

  @@map("users")
}

/// Participação de uma conta individual na distribuição. Hoje só `active`
/// importa: é o liga/desliga do atendente. A fatia dele é automática — as
/// contas individuais dividem em partes iguais o que sobra das % dos grupos.
/// Os três pesos abaixo são herança do modelo antigo (% por atendente), não
/// são mais lidos por nada; ficaram só pra não perder o histórico do que
/// estava configurado.
model DistributionRule {
  id             String  @id @default(cuid())
  operatorId     String  @unique
  operator       User    @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  weightApproved Int     @default(0)
  weightPending  Int     @default(0)
  weightDeclined Int     @default(0)
  active         Boolean @default(true)

  @@map("distribution_rules")
}

/// Grupo de atendimento: quem recebe venda aprovada, e com que fatia. Só
/// weightApproved é lido — pendente e recusado vão pelo rodízio, com a equipe
/// toda. A fatia do grupo se reparte entre as contas dele que estão
/// disponíveis, então quem sai tem a parte absorvida pelos que ficaram.
///
/// A mesma pessoa pode estar em vários grupos (um por demanda, por exemplo):
/// em cada lead, disputam os grupos que têm alguém liberado naquele produtor.
model AttendanceGroup {
  id             String  @id @default(cuid())
  name           String
  weightApproved Int     @default(0)
  weightPending  Int     @default(0)
  weightDeclined Int     @default(0)
  active         Boolean @default(true)
  createdAt      DateTime @default(now())

  members User[] @relation("GroupMembers")

  @@map("attendance_groups")
}

model Producer {
  id                  String   @id @default(cuid())
  name                String
  webhookToken        String   @unique
  smpayWebhookSecret  String?
  kiwifyWebhookSecret String?
  perfectpayToken     String?
  paytIntegrationKey  String?
  lastWebhookGateway  String?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())

  products         Product[]
  leads            Lead[]
  messageTemplates MessageTemplate[]

  @@map("producers")
}

model Product {
  id         String   @id @default(cuid())
  name       String
  sigla      String?
  codigo     String?
  producerId String
  producer   Producer @relation(fields: [producerId], references: [id], onDelete: Cascade)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  accesses ProductAccess[]
  leads    Lead[]

  @@index([producerId])
  @@map("products")
}

/**
 * Per-product, per-operator gate: which categories of that product's leads
 * an operator is allowed to receive, plus an optional daily cap per
 * category (null = no cap, just the allow gate). Once an operator hits
 * their cap for a product today, they're skipped in favor of another
 * operator still under their cap; the limit resets at Brasília midnight
 * since it's derived from today's assigned-lead count, not a stored tally.
 */
model ProductAccess {
  id                 String  @id @default(cuid())
  productId          String
  product            Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  operatorId         String
  operator           User    @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  allowApproved      Boolean @default(false)
  allowPending       Boolean @default(false)
  dailyLimitApproved Int?
  dailyLimitPending  Int?

  @@unique([productId, operatorId])
  @@map("product_access")
}

model Lead {
  id                 String        @id @default(cuid())
  gateway            Gateway
  externalId         String
  producerId         String?
  producer           Producer?     @relation(fields: [producerId], references: [id])
  customerName       String
  phone              String
  email              String?
  /// CPF/CNPJ do comprador, só dígitos.
  document           String?
  product             String?
  /// Código e SKU do produto no gateway de origem — vêm no próprio webhook
  /// (PayT e PerfectPay), sem depender de o produto estar cadastrado aqui.
  productCode         String?
  productSku          String?
  productId           String?
  productRef          Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  value               Decimal?      @db.Decimal(10, 2)
  paymentStatus       PaymentStatus
  serviceStatus       ServiceStatus @default(WAITING)
  assignedOperatorId  String?
  assignedOperator    User?         @relation("AssignedLeads", fields: [assignedOperatorId], references: [id])
  assignedAt          DateTime?
  attendedAt          DateTime?
  usedTemplateId      String?
  usedTemplate        MessageTemplate? @relation(fields: [usedTemplateId], references: [id])
  rawPayload          Json
  createdAt           DateTime      @default(now())

  events LeadEvent[]

  @@unique([producerId, gateway, externalId])
  @@index([createdAt])
  @@index([serviceStatus])
  @@index([assignedOperatorId])
  @@map("leads")
}

model MessageTemplate {
  id         String   @id @default(cuid())
  title      String
  content    String
  active     Boolean  @default(true)
  operatorId String?
  operator   User?    @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  /// Produtor dono da mensagem: ela só aparece nos leads dele. Nulo quer dizer
  /// que serve pra qualquer lead — é onde ficam as mensagens antigas, criadas
  /// antes de existir essa separação. O vínculo é pelo produtor, e não pelo
  /// produto, porque é o produtor que vem certo em todo lead (o gateway manda
  /// nome de oferta, que não bate com o produto cadastrado).
  producerId String?
  producer   Producer? @relation(fields: [producerId], references: [id], onDelete: Cascade)

  leads Lead[]

  @@index([operatorId])
  @@index([producerId])
  @@map("message_templates")
}

/**
 * Independent from the Lead pipeline: a sale the operator personally
 * converted, reported by their own gateway webhook — purely for the
 * sales-count ranking, not routed through the distribution engine.
 */
model OperatorSale {
  id            String        @id @default(cuid())
  operatorId    String
  operator      User          @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  gateway       Gateway
  externalId    String
  customerName  String?
  value         Decimal?      @db.Decimal(10, 2)
  paymentStatus PaymentStatus @default(APPROVED)
  rawPayload    Json
  createdAt     DateTime      @default(now())

  @@unique([operatorId, gateway, externalId])
  @@index([operatorId, createdAt])
  @@map("operator_sales")
}

model LeadEvent {
  id         String           @id @default(cuid())
  leadId     String
  lead       Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  operatorId String
  operator   User             @relation(fields: [operatorId], references: [id])
  action     LeadEventAction
  createdAt  DateTime         @default(now())

  @@index([operatorId, createdAt])
  @@map("lead_events")
}
